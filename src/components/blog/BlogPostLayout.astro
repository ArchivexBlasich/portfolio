---
import type { ImageMetadata } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostMeta from "./PostMeta.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import { t } from "../../i18n/ui";

interface Props {
  locale: "en" | "es";
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
}

const { locale, title, description, pubDate, updatedDate, heroImage } =
  Astro.props;
---

<BaseLayout locale={locale} title={title} description={description}>
  <main id="main" class="container py-16">
    <article>
      {
        heroImage && (
          <img
            src={heroImage.src}
            alt=""
            class="mb-8 aspect-video w-full rounded-lg object-cover"
          />
        )
      }

      <h1 class="text-3xl">{title}</h1>

      <div class="mt-2">
        <PostMeta pubDate={pubDate} updatedDate={updatedDate} locale={locale} />
      </div>

      <div class="prose dark:prose-invert mt-8 max-w-prose leading-relaxed">
        <slot />
      </div>

      <a
        href={getRelativeLocaleUrl(locale, "blog")}
        class="text-brand hover:text-brand-hover mt-12 inline-block text-sm"
      >
        {t("blog.backToList", locale)}
      </a>
    </article>
  </main>
</BaseLayout>
