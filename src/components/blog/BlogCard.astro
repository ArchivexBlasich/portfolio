---
import type { ImageMetadata } from "astro";
import PostMeta from "./PostMeta.astro";

interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  heroImage?: ImageMetadata;
  locale: "en" | "es";
}

const { href, title, description, pubDate, heroImage, locale } = Astro.props;
---

<article
  class="border-border bg-surface-raised group hover:border-brand/40 relative rounded-lg border p-4 transition-all duration-200 hover:shadow-md"
>
  {
    heroImage && (
      <img
        src={heroImage.src}
        alt=""
        class="mb-4 aspect-video w-full rounded-md object-contain"
      />
    )
  }

  <h2 class="text-xl">
    <a
      href={href}
      class="text-text group-hover:text-brand underline-offset-2 transition-colors after:absolute after:inset-0"
    >
      {title}
    </a>
  </h2>

  <p class="text-text-subtle mt-2 text-sm">{description}</p>

  <div class="mt-3">
    <PostMeta pubDate={pubDate} locale={locale} />
  </div>
</article>
