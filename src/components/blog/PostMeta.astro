---
import { t } from "../../i18n/ui";

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  locale: "en" | "es";
}

const { pubDate, updatedDate, locale } = Astro.props;

const fmt = (date: Date) =>
  new Intl.DateTimeFormat(locale === "en" ? "en-US" : "es-AR", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
---

<p class="text-text-muted text-sm">
  {t("blog.postedOn", locale)}
  {fmt(pubDate)}
  {
    updatedDate && (
      <>
        — {t("blog.updatedOn", locale)} {fmt(updatedDate)}
      </>
    )
  }
</p>
