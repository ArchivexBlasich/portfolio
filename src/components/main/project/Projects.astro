---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import ProjectGroup from "./ProjectGroup.astro";
import { t } from "../../../i18n/ui";

const { locale } = Astro.props;

const rawProjects = await getCollection("projects", (entry) =>
  entry.id.startsWith(locale + "/"),
);

const sortByOrder = (
  a: (typeof rawProjects)[number],
  b: (typeof rawProjects)[number],
) => {
  const orderA = a.data.order ?? Infinity;
  const orderB = b.data.order ?? Infinity;
  if (orderA !== orderB) return orderA - orderB;
  return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
};

const standaloneProjects = rawProjects
  .filter((p) => !p.data.group)
  .sort(sortByOrder);

const groupMap = new Map<string, typeof rawProjects>();
for (const p of rawProjects.filter((p) => p.data.group)) {
  const key = p.data.group!;
  if (!groupMap.has(key)) groupMap.set(key, []);
  groupMap.get(key)!.push(p);
}

const groups = [...groupMap.entries()]
  .map(([name, entries]) => ({
    name,
    entries: entries.sort(sortByOrder),
    minOrder: Math.min(...entries.map((e) => e.data.order ?? Infinity)),
  }))
  .sort((a, b) => a.minOrder - b.minOrder);
---

<section class="mt-12 mb-7 scroll-mt-20" id="projects">
  <div class="prose lg:prose-xl mt-12 mb-8 text-center md:text-left">
    <h1 id="work" class="text-brand underline">
      {t("projects.heading", locale)}
    </h1>
  </div>
  <div class="flex flex-col gap-12">
    {
      standaloneProjects.map((entry) => (
        <ProjectCard project={entry} locale={locale} />
      ))
    }
    {
      groups.map((group) => (
        <ProjectGroup
          title={group.name}
          projects={group.entries}
          locale={locale}
        />
      ))
    }
  </div>
</section>
