---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";
import { t } from "../../../i18n/ui";

const { locale } = Astro.props;

const rawProjects = await getCollection("projects", (entry) =>
  entry.id.startsWith(locale + "/"),
);

const projects = rawProjects.sort((a, b) => {
  // Primary: order ascending
  const orderA = a.data.order ?? Infinity;
  const orderB = b.data.order ?? Infinity;
  if (orderA !== orderB) return orderA - orderB;
  // Fallback: featured projects first
  return (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0);
});
---

<section class="mt-12 mb-7 scroll-mt-20" id="projects">
  <div class="prose lg:prose-xl mt-12 mb-8 text-center md:text-left">
    <h1 id="work" class="text-brand underline">
      {t("projects.heading", locale)}
    </h1>
  </div>
  <div class="flex flex-col gap-12">
    {projects.map((entry) => <ProjectCard project={entry} locale={locale} />)}
  </div>
</section>
