---
import { Image } from "astro:assets";
import type { Project } from "../../../data/projects";
import Button from "../../Button.astro";
import ProjectPill from "./ProjectPill.astro";

interface Props {
  project: Project;
}

const {
  project: { title, description, image, tags, githubUrl, liveUrl },
} = Astro.props;
---

<article class="grid grid-cols-1 md:grid-cols-5 gap-8">
  <div class="md:col-span-2 rounded-lg">
    <div class="relative group">
      <Image
        src={image}
        alt={`Screenshot of ${title}`}
        class="rounded-lg shadow-lg"
      />
      <div
        class="absolute inset-0 rounded-lg bg-surface/20 group-hover:bg-surface/40 transition-colors"
      >
      </div>
    </div>
  </div>
  <div class="md:col-span-3 flex flex-col justify-center">
    <h3 class="text-2xl font-semibold text-text mb-4">{title}</h3>
    <p class="text-text-subtle mb-6">{description}</p>
    <div class="flex flex-wrap gap-2 mb-6">
      {tags.map((tag) => <ProjectPill tag={tag} />)}
    </div>
    <div class="flex gap-4">
      {
        liveUrl && (
          <Button
            href={liveUrl}
            target="_blank"
            rel="noopener noreferrer"
            variant="primary"
          >
            Live Demo
          </Button>
        )
      }
      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View source on GitHub"
        class="group
    relative
    flex items-center justify-center
    p-3
    rounded-full
    bg-surface-raised/80
    border border-border
    text-text-subtle
    shadow-sm
    transition-all duration-300
    hover:bg-surface-raised
    hover:border-text-muted
    hover:text-text
    hover:shadow-surface/50
    hover:shadow-md"
      >
        <svg
          class="w-6 h-6 transition-transform duration-300 group-hover:scale-110"
          viewBox="0 0 1024 1024"
          fill="currentColor"
        >
          <use href="/sprite.svg#github_dark"></use>
        </svg>
      </a>
    </div>
  </div>
</article>
