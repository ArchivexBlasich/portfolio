---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span
  class="flex cursor-default items-center justify-center rounded-full border border-rose-100 bg-rose-200 px-2.5 py-0.5 text-sm text-rose-800 transition-all duration-300 ease-in-out select-none hover:scale-105 hover:bg-rose-300 hover:shadow-sm dark:border-rose-600 dark:bg-rose-800 dark:text-rose-200 dark:hover:bg-rose-600"
>
  {tag}
</span>
