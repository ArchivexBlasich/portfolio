---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span
  class="
    flex items-center justify-center
    px-2.5 py-0.5
    text-sm
    rounded-full
    
    bg-rose-200 text-rose-800
    border border-rose-100
    
    dark:bg-rose-800 dark:text-rose-200 dark:border-rose-600
    
    transition-all duration-300 ease-in-out
    hover:scale-105
    hover:bg-rose-300 dark:hover:bg-rose-600
    hover:shadow-sm
    cursor-default
    select-none
  "
>
  {tag}
</span>