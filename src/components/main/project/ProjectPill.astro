---
interface Props {
  tag: string;
}

const { tag } = Astro.props;
---

<span
  class="border-brand bg-brand-faint hover:bg-brand hover:text-brand-text dark:border-brand dark:bg-brand dark:text-brand-text flex cursor-default items-center justify-center rounded-full border px-2.5 py-0.5 text-sm text-[var(--color-rose-800)] transition-all duration-300 ease-in-out select-none hover:scale-105 hover:shadow-sm"
>
  {tag}
</span>
