---
import { t } from "../../../i18n/ui";
import deployImage from "../../../assets/blog/deploy-vps.png";

interface Props {
  deployHref?: string;
  locale: "en" | "es";
  class?: string;
}

const { deployHref, locale, class: className } = Astro.props;
---

<article
  class:list={[
    "border-border bg-surface-raised flex flex-col rounded-lg border p-4",
    className,
  ]}
>
  <h3 class="text-xl font-bold">
    {
      deployHref ? (
        <a
          href={deployHref}
          class="text-brand hover:text-brand-hover underline underline-offset-2 transition-colors"
          aria-label={`${t("deployCta.cta", locale)} — ${t("deployCta.heading", locale)}`}
        >
          {t("deployCta.heading", locale)}
        </a>
      ) : (
        <span class="text-text">{t("deployCta.heading", locale)}</span>
      )
    }
  </h3>

  <p class="text-text-subtle mt-2 text-sm">
    {t("deployCta.description", locale)}
  </p>

  {
    !deployHref && (
      <span class="text-text-muted mt-3 inline-block text-sm">
        {t("deployCta.comingSoon", locale)}
      </span>
    )
  }

  <div class="mt-4 flex flex-1 items-center justify-center">
    <img
      src={deployImage.src}
      alt=""
      width={deployImage.width}
      height={deployImage.height}
      class="max-h-48 w-full object-contain opacity-80"
      loading="lazy"
    />
  </div>
</article>
