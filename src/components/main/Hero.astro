---
import { Image } from "astro:assets";
import profileImg from "../../assets/ProfilePicture.png";
import SocialMedia from "../socialMedia/SocialMedia.astro";
---

<section
  class="prose lg:prose-xl mt-1 flex flex-col items-center justify-center self-center-safe"
>
  <Image
    src={profileImg}
    alt="Fabricio Blasich's Profile Picture"
    quality="mid"
    class="size-56 object-cover md:size-65 lg:size-70"
  />
  <h2 class="text-text-muted text-center">Fabricio Blasich</h2>
  <h1 class="text-text text-center">Computer Engineer</h1>
  <SocialMedia />
</section>
