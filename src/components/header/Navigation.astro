---
import Link from "../Link.astro";
import { t } from "../../i18n/ui";

const { locale } = Astro.props;
---

<div class="contents">
  <button
    id="menu-btn"
    aria-expanded="false"
    aria-label={t("nav.menu.aria", locale)}
    class="text-text -mr-2 ml-auto block min-h-[44px] min-w-[44px] cursor-pointer p-3 md:hidden"
  >
    <svg
      class="h-8 w-8 fill-current"
      viewBox="0 0 20 20"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"></path>
    </svg>
  </button>

  <div
    id="nav-links"
    class="border-border mt-4 grid w-full basis-full grid-rows-[0fr] border-t opacity-0 transition-all duration-300 ease-in-out md:mt-0 md:block md:w-auto md:basis-auto md:grid-rows-none md:border-none md:opacity-100"
  >
    <nav
      aria-label={t("nav.main.aria", locale)}
      class="grid min-h-0 grid-rows-[1fr] overflow-hidden md:block"
    >
      <div
        class="flex flex-col items-center py-4 text-center md:flex-row md:gap-8 md:py-0"
      >
        <Link href="#about">{t("nav.about", locale)}</Link>
        <Link href="#work">{t("nav.work", locale)}</Link>
        <Link href="#projects">{t("nav.projects", locale)}</Link>
        <Link href="#contact">{t("nav.contact", locale)}</Link>
      </div>
    </nav>
  </div>
</div>

<script>
  const btn = document.getElementById("menu-btn");
  const nav = document.getElementById("nav-links");

  btn?.addEventListener("click", () => {
    nav?.classList.toggle("grid-rows-[0fr]");
    nav?.classList.toggle("grid-rows-[1fr]");

    nav?.classList.toggle("opacity-0");
    nav?.classList.toggle("opacity-100");

    const isExpanded = nav?.classList.contains("grid-rows-[0fr]")
      ? "false"
      : "true";
    btn.setAttribute("aria-expanded", isExpanded);
  });
</script>
