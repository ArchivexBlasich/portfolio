---
import Link from "../Link.astro";
---

<div class="contents"> 
  <button 
    id="menu-btn"
    aria-expanded="false" 
    aria-label="Open Menu"
    class="md:hidden block p-2 -mr-2 text-slate-900 dark:text-white focus:outline-none ml-auto cursor-pointer"
  >
    <svg class="w-8 h-8 fill-current" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
      <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"></path>
    </svg>
  </button>

  <div 
    id="nav-links" 
    class="
      w-full basis-full border-t border-slate-200 dark:border-slate-800 mt-4 
      grid transition-all duration-300 ease-in-out
      grid-rows-[0fr] opacity-0
      md:block md:w-auto md:basis-auto md:mt-0 md:border-none md:grid-rows-none md:opacity-100
    "
  >
    <div class="flex flex-col md:flex-row md:gap-8 items-center text-center py-4 md:py-0 overflow-hidden">
      <Link href="#about">About</Link>
      <Link href="#work">Work</Link>
      <Link href="#contact">Contact</Link>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('menu-btn');
  const nav = document.getElementById('nav-links');

  btn?.addEventListener('click', () => {
    nav?.classList.toggle('grid-rows-[0fr]');
    nav?.classList.toggle('grid-rows-[1fr]');
    
    nav?.classList.toggle('opacity-0');
    nav?.classList.toggle('opacity-100');

    const isExpanded = nav?.classList.contains('grid-rows-[0fr]') ? 'false' : 'true';
    btn.setAttribute('aria-expanded', isExpanded);
  });
</script>