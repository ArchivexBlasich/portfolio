---
import type { HTMLAttributes } from "astro/types";

interface LinkProps extends HTMLAttributes<"a"> {
  href: string;
  type?: never;
}

interface ButtonProps extends HTMLAttributes<"button"> {
  href?: never;
}

type Props = (LinkProps | ButtonProps) & {
  variant?: "primary" | "secondary";
};

const { href, class: className, variant = "primary", ...rest } = Astro.props;

const commonClasses = [
  "inline-block font-semibold no-underline tracking-tighter rounded-md cursor-pointer",
  "px-4 py-2 text-slate-100",
  "transition-all duration-300 transform",
  "hover:-translate-y-1",
];

const primaryClasses = [
  "btn-glow",
  "bg-rose-600",
];

const secondaryClasses = [
  "bg-transparent",
  "border border-slate-700",
  "hover:bg-slate-800",
];

const finalClasses = [
  ...commonClasses,
  ...(variant === "primary" ? primaryClasses : secondaryClasses),
  className,
];
---

{
  href ? (
    <a
      href={href}
      class:list={finalClasses}
      {...(rest as HTMLAttributes<"a">)}
    >
      <slot />
    </a>
  ) : (
    <button
      class:list={finalClasses}
      {...(rest as HTMLAttributes<"button">)}
    >
      <slot />
    </button>
  )
}

<style>
  .btn-glow {
    box-shadow:
      0 2px 5px color-mix(in srgb, var(--color-rose-600), transparent 90%),
      0 1px 1px color-mix(in srgb, var(--color-rose-600), transparent 90%),
      0 0 10px 0px var(--color-rose-600);
  }

  .btn-glow:hover {
    box-shadow:
      0 3px 7px color-mix(in srgb, var(--color-rose-600), transparent 95%),
      0 2px 2px color-mix(in srgb, var(--color-rose-600), transparent 98%),
      0 0 20px 0px var(--color-rose-600);
  }
</style>
