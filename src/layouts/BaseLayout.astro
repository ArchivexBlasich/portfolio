---
import Header from "../components/header/Header.astro";
import "../styles/global.css";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <!-- FOUC prevention: runs synchronously before first paint.
         Priority: localStorage > system preference > dark default.
         Fixes comment-code divergence (obs #20): code previously hardcoded
         dark fallback when no localStorage, ignoring prefers-color-scheme. -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        let isDark;
        if (stored !== null) {
          isDark = stored !== "light";
        } else {
          isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        }
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>
  <body class="bg-surface text-text min-h-dvh font-mono antialiased">
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <slot />
  </body>
</html>
