---
import Header from "../components/header/Header.astro";
import "../styles/global.css";
import { getRelativeLocaleUrl } from "astro:i18n";
import { t } from "../i18n/ui";

const { locale = "en", title = t("site.title", locale) } = Astro.props;

// Current path without locale prefix — for hreflang/computation
const currentPath = Astro.url.pathname;
// With prefixDefaultLocale: false, only non-default locale (es) has a URL prefix.
// English pages at /, /404 have no prefix to strip — the old regex /^\/[^\/]+/
// would incorrectly treat "/404" as a locale segment on the root 404 page.
const pathWithoutLocale =
  currentPath.startsWith("/es/") || currentPath === "/es"
    ? currentPath.replace(/^\/es/, "") || "/"
    : currentPath;
const cleanPath = pathWithoutLocale === "/" ? "" : pathWithoutLocale;

// Locale-aware SEO values
const ogLocale = locale === "en" ? "en_US" : "es_AR";
const altOgLocale = locale === "en" ? "es_AR" : "en_US";
const enUrl = new URL(getRelativeLocaleUrl("en", cleanPath), Astro.site);
const esUrl = new URL(getRelativeLocaleUrl("es", cleanPath), Astro.site);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const description = t("meta.description", locale);

// JSON-LD Person schema with per-page locale (REQ-009)
const jsonLd = JSON.stringify(
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: "Fabricio Blasich",
    jobTitle: "Computer Engineer",
    url: "https://fabricioblasich.com",
    sameAs: [
      "https://github.com/ArchivexBlasich",
      "https://www.linkedin.com/in/fabricio-lucas-blasich",
    ],
    inLanguage: locale,
    knowsLanguage: ["en", "es"],
    knowsAbout: [
      "Computer Engineering",
      "Systems Architecture",
      "Software Engineering",
      "Computer Networking",
      "Embedded Systems",
      "Artificial Intelligence",
      "TypeScript",
      "Astro",
      "Tailwind CSS",
    ],
    address: {
      "@type": "PostalAddress",
      addressCountry: "AR",
    },
  },
  null,
  2,
);
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="/og-default.png" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={altOgLocale} />
    <meta property="og:site_name" content="Fabricio Blasich" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-default.png" />

    <!-- Canonical URL — self-referencing per locale -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang alternates: en-US, es-AR, x-default (match sitemap-0.xml) -->
    <link rel="alternate" hreflang="en-US" href={enUrl} />
    <link rel="alternate" hreflang="es-AR" href={esUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <!-- Author, theme-color (unchanged) -->
    <meta name="author" content="Fabricio Blasich" />
    <meta name="theme-color" content="#e11d48" />
    <meta
      name="theme-color"
      content="#e11d48"
      media="(prefers-color-scheme: dark)"
    />

    <!-- JSON-LD Person Schema — per-page inLanguage from locale prop (REQ-009) -->
    <script type="application/ld+json" set:html={jsonLd} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- FOUC prevention — UNCHANGED (theme only, language is URL-based) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        let isDark;
        if (stored !== null) {
          isDark = stored !== "light";
        } else {
          isDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        }
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>
  <body class="bg-surface text-text min-h-dvh font-mono antialiased">
    <a href="#main" class="skip-link">{t("skip.text", locale)}</a>
    <Header locale={locale} />
    <slot />
  </body>
</html>
