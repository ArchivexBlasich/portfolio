---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import BlogCard from "../../../components/blog/BlogCard.astro";
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { t } from "../../../i18n/ui";

export async function getStaticPaths() {
  return [{ params: { locale: "es" } }];
}

const { locale } = Astro.params;

if (!locale || (locale !== "en" && locale !== "es")) {
  throw new Error(`Invalid locale: ${locale}`);
}

const posts = (await getCollection("blog"))
  .filter((e) => e.id.startsWith("es/") && !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout
  locale={locale}
  title={t("blog.emptyStateTitle", locale)}
  description={t("meta.description", locale)}
>
  <main id="main" class="container py-16">
    <h1 class="text-3xl">{t("blog.emptyStateTitle", locale)}</h1>

    {
      posts.length === 0 ? (
        <p class="text-text-muted mt-4">{t("blog.emptyStateBody", locale)}</p>
      ) : (
        <div class="mt-8 grid gap-6">
          {posts.map((p) => (
            <BlogCard
              href={getRelativeLocaleUrl(
                locale,
                `blog/${p.id.replace(/^es\//, "")}`,
              )}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.date}
              heroImage={p.data.image}
              locale={locale}
            />
          ))}
        </div>
      )
    }
  </main>
</BaseLayout>
