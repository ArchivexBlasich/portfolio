---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found">
  <main
    class="flex min-h-dvh flex-col items-center justify-center gap-6 px-4 text-center"
  >
    <p class="text-brand font-mono text-9xl font-bold tracking-tighter">404</p>
    <h1 class="text-text font-mono text-2xl font-semibold">Page not found</h1>
    <p class="text-text-subtle max-w-md font-mono">
      The page you are looking for does not exist or has been moved.
    </p>
    <a
      href="/"
      class="bg-brand-bg text-brand-text inline-block transform cursor-pointer rounded-md px-4 py-2 font-semibold tracking-tighter no-underline transition-all duration-300 hover:-translate-y-1 hover:shadow-md"
    >
      Back to home
    </a>
  </main>
</BaseLayout>
